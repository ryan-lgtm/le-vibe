# Monorepo (root) — keep clones clean for editor vendoring + Debian parent-dir artifacts
.venv/
__pycache__/
.pytest_cache/
le-vibe/.pytest-verify-step14-contract.lock
*.py[cod]
*.egg-info/

# Built Debian artifacts (often next to debian/ at repo root)
*.deb
packaging/debian-le-vibe-ide/staging/
packaging/appimage/AppDir/
packaging/*.AppImage
flatpak-build-dir/
*.buildinfo
*.changes

# CI/build outputs (SBOM, checksums, IDE metadata — regenerated by workflows; do not commit)
/artifacts/

# Local IDE compile env (optional; see editor/le-vibe-overrides/build-env.sh.example)
editor/le-vibe-overrides/build-env.sh

# Lé Vibe compile hook — sed backup next to dev/build.sh (ci-vscodium-linux-dev-build.sh)
editor/vscodium/dev/build.sh.bak_lvibe

# Regenerated by editor/le-vibe-overrides/sync-linux-icon-assets.sh (§7.3 Linux icons)
editor/vscodium/src/stable/resources/linux/le-vibe.svg
editor/vscodium/src/stable/resources/linux/le-vibe.png

# Editor (Code OSS / VSCodium) — when populated
editor/**/node_modules/
editor/**/out/
editor/**/.build/

# Debian build droppings (regenerated by dpkg-buildpackage)
debian/.debhelper/
debian/files
debian/*.substvars
debian/*.debhelper.log
debian/debhelper-build-stamp
debian/le-vibe/

# Nested IDE `.deb` packaging tree (same droppings as root `debian/`)
packaging/debian-le-vibe-ide/debian/debhelper-build-stamp
packaging/debian-le-vibe-ide/debian/.debhelper/
packaging/debian-le-vibe-ide/debian/files
packaging/debian-le-vibe-ide/debian/*.substvars
packaging/debian-le-vibe-ide/debian/*.debhelper.log
packaging/debian-le-vibe-ide/debian/le-vibe-ide/
