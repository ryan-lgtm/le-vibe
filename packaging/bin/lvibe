#!/bin/sh
# Lé Vibe — primary PATH CLI (PRODUCT_SPEC §2 / §7.3); opens the editor with optional workspace path (e.g. lvibe .).
# le-vibe is an optional compatibility entrypoint to the same launcher — prefer lvibe for docs and scripts.
# Product / trust: docs/PRODUCT_SPEC.md (launcher, §5 `.lvibe/` consent); spec-phase2.md §14 (H6/H7 vs in-tree; STEP 14 E1 — editor/le-vibe-overrides/README.md + le-vibe/tests/test_editor_le_vibe_overrides_readme_contract.py); docs/README.md (§9 Maintainer index; H8 — .github/ (ci.yml, dependabot.yml, ISSUE_TEMPLATE + config.yml # H8); SECURITY; privacy-and-telemetry E1).
# Full E1 pytest roster: project root README.md Tests / E1 mapping; spec-phase2.md §14 Honesty vs CI (same pointers as ci.yml, dependabot.yml).
# H1 / §7.3: default ci.yml le-vibe-deb is stack-only; maintainer full product: build-le-vibe-debs.sh --with-ide prints Full-product install — docs/PM_DEB_BUILD_ITERATION.md; docs/apt-repo-releases.md (IDE package); docs/PM_STAGE_MAP.md (H1 vs §7.3 .deb bundles).
# Optional RAG: docs/rag/le-vibe-phase2-chunks.md (spec-phase2 §14 table; not pytest) — SECURITY Related docs; packaging/scripts/ci-smoke.sh + .github/workflows/ci.yml headers.
# Master orchestrator: 0 → 1 → 14 → 2–13 → 15–17 — docs/PROMPT_BUILD_LE_VIBE.md (ORDERED WORK QUEUE, Rolling iteration); docs/PM_STAGE_MAP.md (Execution order / STEP 16) — primary PATH CLI `lvibe` (§2 / §7.3 stack + IDE story).
# Pytest: le-vibe/tests/test_packaging_bin_sh_launchers_contract.py; verify JSON stubs —
#   le-vibe/tests/test_verify_step14_closeout_contract.py (fcntl lock; .gitignore: le-vibe/.pytest-verify-step14-contract.lock).
# Requires: python3 on PATH.
export PYTHONPATH="/usr/share/le-vibe/le-vibe:/usr/share/le-vibe${PYTHONPATH:+:$PYTHONPATH}"
# Default editor resolution lives in le_vibe.launcher (14.g): /usr/lib/le-vibe/bin/codium, then codium — do not force LE_VIBE_EDITOR here.
if ! command -v python3 >/dev/null 2>&1; then
  echo "lvibe: python3 not on PATH — install Python 3 (e.g. sudo apt install python3)." >&2
  exit 127
fi
exec python3 -m le_vibe.launcher "$@"
