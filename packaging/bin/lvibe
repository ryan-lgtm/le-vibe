#!/bin/sh
# Lé Vibe default CLI — same as le-vibe; opens the editor with optional workspace path (e.g. lvibe .).
# Product / trust: docs/PRODUCT_SPEC.md (launcher, §5 `.lvibe/` consent); spec-phase2.md §14 (H6/H7 vs in-tree; STEP 14 E1 — editor/le-vibe-overrides/README.md + le-vibe/tests/test_editor_le_vibe_overrides_readme_contract.py); docs/README.md (§9 Maintainer index; H8 — .github/ (ci.yml, dependabot.yml, ISSUE_TEMPLATE + config.yml # H8); SECURITY; privacy-and-telemetry E1).
# Full E1 pytest roster: project root README.md Tests / E1 mapping; spec-phase2.md §14 Honesty vs CI (same pointers as ci.yml, dependabot.yml).
# Optional RAG: docs/rag/le-vibe-phase2-chunks.md (spec-phase2 §14 table; not pytest) — SECURITY Related docs; packaging/scripts/ci-smoke.sh + .github/workflows/ci.yml headers.
export PYTHONPATH="/usr/share/le-vibe${PYTHONPATH:+:$PYTHONPATH}"
# Default editor resolution lives in le_vibe.launcher (14.g): le-vibe-ide, then codium — do not force LE_VIBE_EDITOR here.
exec python3 -m le_vibe.launcher "$@"
